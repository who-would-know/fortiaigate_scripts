# FortiAIGate Scripts — Environment Variables
# ---------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!
#
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env  (Windows)
# ---------------------------------------------------

# Your FortiAIGate proxy URL including /v1 at the end
# e.g. https://192.168.1.10:8443/v1
FORTIAIG_URL=https://your-fortiaig-ip:port/v1

# Your OpenAI API key (get it from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...
